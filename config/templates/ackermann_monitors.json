{
  "operationName": "AdditionalInfiniteCategoryProductGridData",
  "query": "query AdditionalInfiniteCategoryProductGridData($params: SearchParametersInput!, $pathname: String!) { category(params: $params, pathname: $pathname) { __typename ... on CategoryResult { items { styleName brand { name } primaryVariationGroup { href image price { currentPrice discount { previousPrice } } } } summary { totalResultCount } } } }",
  "variables": {
    "params": {
      "constraints": {
        "appliedFilters": [
          { "filterId": "filter_Bildschirmdiagonale in Zoll", "values": ["fb_bldsc.ll_4044.ll_5c", "fb_bldsc.ll_4549.ll_f0", "fb_bldsc.ll_3539.ll_a6"] },
          { "filterId": "filter_primary_produkttyp", "values": ["fb_prmry.yp_crvd.tr_24"] },
          { "filterId": "filter_price", "values": ["{min_price}-{max_price}"] }
        ]
      },
      "environment": { "channel": "DESKTOP", "isBot": false, "isMonitoring": false, "locale": "de-CH" },
      "paging": { "limit": 72, "offset": {offset}, "sortBy": "price-asc" },
      "tracking": { "sessionId": "1092:w:00000000-0000-0000-0000-000000000000", "userConsent": false },
      "unifiedFilterHandling": true,
      "version": "22"
    },
    "pathname": "/technik/multimedia/pcs-monitore/"
  }
}
